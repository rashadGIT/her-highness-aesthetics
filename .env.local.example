# ─────────────────────────────────────────────────
# Her Highness Aesthetics — Environment Variables
# Copy this to .env.local and fill in all values
# NEVER commit .env.local to git
# ─────────────────────────────────────────────────

# ── Site Config ──────────────────────────────────
# Your Amplify deployment URL (update after first deploy)
NEXT_PUBLIC_SITE_URL=https://main.xxxxxx.amplifyapp.com

# ── AWS Config ───────────────────────────────────
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_access_key_id
AWS_SECRET_ACCESS_KEY=your_secret_access_key

# ── DynamoDB ─────────────────────────────────────
DYNAMODB_BOOKINGS_TABLE=hha-bookings
DYNAMODB_BLOCKED_DATES_TABLE=hha-blocked-dates

# ── SES (Email) ──────────────────────────────────
SES_FROM_EMAIL=hhaesthetics25@gmail.com
SES_REPLY_TO=hhaesthetics25@gmail.com

# ── Admin Auth ───────────────────────────────────
ADMIN_EMAIL=hhaesthetics25@gmail.com
# Generate with: node -e "require('bcryptjs').hash('YOUR_PASSWORD', 12).then(console.log)"
ADMIN_PASSWORD_HASH=$2b$12$xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── NextAuth ─────────────────────────────────────
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=your_nextauth_secret_here
NEXTAUTH_URL=https://main.xxxxxx.amplifyapp.com

# ── Stripe ───────────────────────────────────────
# Get from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_xxxxxxxxxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_xxxxxxxxxx
# Get from Stripe webhook settings
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxx

# ── AWS S3 (File Uploads) ────────────────────────
S3_UPLOADS_BUCKET=hha-uploads
# CloudFront domain for public gallery images
NEXT_PUBLIC_CLOUDFRONT_DOMAIN=https://xxxxxxxxxx.cloudfront.net

# ── n8n Automation ───────────────────────────────
# Your n8n webhook base URL (n8n Cloud or self-hosted)
N8N_WEBHOOK_URL=https://your-n8n-instance/webhook
